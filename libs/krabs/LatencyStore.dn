uses libs.krabs.KrabsSettings

const int MAX_LATENCY_STORE_SIZE = 10
const char APPLICATION_NAME[] = KrabsSettings.APP_NAME
const char KRABS_HOST[] = KrabsSettings.HOST
const char KRABS_PORT[] = KrabsSettings.PORT

component provides libs.krabs.LatencyStore requires time.Calendar ic, time.DateUtil du,
    net.http.HTTPRequest req, data.IntUtil iu, libs.utils.Logger logger {
    static int latencyStore[] = new int[]()

    int LatencyStore:getMilisecondsExecutionTimeSince(DateTime start) {
        DateTime now = ic.getTime()
        return du.toMilliseconds(du.diff(now, start))
    }

    void LatencyStore:storeExecutionTime(int miliseconds) {
        latencyStore = new int[](latencyStore, miliseconds)
        logger.info("Execution time stored: $(iu.makeString(miliseconds)) ms")
        logger.info("Store size: $(iu.makeString(latencyStore.arrayLength))")

        if(latencyStore.arrayLength > MAX_LATENCY_STORE_SIZE) {
            int avarageLatency = getAverageFromLatencyStore()
            logger.info("Avarage latency from last $(iu.makeString(MAX_LATENCY_STORE_SIZE)) executions: $(iu.makeString(avarageLatency)) ms")
            char body[] = "{"
            body = new char[](body, "\"target\": \"$APPLICATION_NAME\",")
            body = new char[](body, "\"type\": \"latency\",")
            body = new char[](body, "\"value\": \"$(iu.makeString(avarageLatency))\"")
            body = new char[](body, "}")
            logger.info("Sending latency data to Krabs: $body")
            logger.info("Krabs endpoint: http://$KRABS_HOST:$KRABS_PORT/telemetry")
            Header headers[] = new Header[](new Header("Content-Type", "application/json"))
            req.post("http://$KRABS_HOST:$KRABS_PORT/telemetry", headers, body)
            latencyStore = new int[]()
        }
    }

    int getAverageFromLatencyStore() {
        int total = 0
        for (int i = 0; i < latencyStore.arrayLength; i++) {
            total += latencyStore[i]
        }
        return total / latencyStore.arrayLength
    }
}
