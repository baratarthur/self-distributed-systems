uses libs.utils.Constants
uses libs.utils.DatabaseConfig

const char debugMSG[] = "[@PostsRepository]"
const int PAGINATION_SIZE = 10
const int CONNECTION_READ_POOL_SIZE = 90
const int CONNECTION_WRITE_POOL_SIZE = 10

component provides repositories.posts.PostsRepository(Destructor) requires io.Output out, time.DateUtil du, time.Calendar ic, data.IntUtil iu, data.mysql.MySQL {
    MySQL dbs_read[] = new MySQL[]()
    MySQL dbs_write[] = new MySQL[]()

    int connectionRead = 0
    int connectionWrite = 0
    static Mutex connectionReadLock = new Mutex()
    static Mutex connectionWriteLock = new Mutex()

    void PostsRepository:createConnectionPool() {
        if(dbs_read.arrayLength == 0) {
            for(int i = 0; i < CONNECTION_READ_POOL_SIZE; i++) {
                out.println("Init connection read $(iu.makeString(i))")
                MySQL db = new MySQL(DatabaseConfig.host,
                                    DatabaseConfig.port,
                                    DatabaseConfig.user,
                                    DatabaseConfig.password,
                                    DatabaseConfig.databaseName)
                dbs_read = new MySQL[](dbs_read, db)
            }
        }
        if(dbs_write.arrayLength == 0) {
            for(int i = 0; i < CONNECTION_WRITE_POOL_SIZE; i++) {
                out.println("Init connection write $(iu.makeString(i))")
                MySQL db = new MySQL(DatabaseConfig.host,
                                    DatabaseConfig.port,
                                    DatabaseConfig.user,
                                    DatabaseConfig.password,
                                    DatabaseConfig.databaseName)
                dbs_write = new MySQL[](dbs_write, db)
            }
        }
    }

    MySQL getDbConnection(char type) {
        MySQL db
        if(type == "r") {
            mutex(connectionReadLock) {
                db = dbs_read[connectionRead]
                connectionRead = (connectionRead + 1) % CONNECTION_READ_POOL_SIZE
            }
        } else {
            mutex(connectionWriteLock) {
                db = dbs_write[connectionWrite]
                connectionWrite = (connectionWrite + 1) % CONNECTION_WRITE_POOL_SIZE
            }
        }
        return db
    }
    
    void Destructor:destroy() {
        for(int i = 0; i < dbs_read.arrayLength; i++) {
            dbs_read[i].close()
        }
        for(int i = 0; i < dbs_write.arrayLength; i++) {
            dbs_write[i].close()
        }
    }

    void PostsRepository:addPost(store Post newPost) {
        postsWrite = new Post[](postsWrite, newPost) // add to cache
        out.println("writing post")
        if(postsWrite.arrayLength > 10) { // simple cache eviction policy
            out.println("writing in database")
            char query[] = "INSERT INTO posts (userId, content) VALUES "
            for (int i = 0; i < postsWrite.arrayLength - 1; i++) {
                query = new char[](query, "($(iu.makeString(postsWrite[i].userId)), '$(postsWrite[i].content)')")
                if (i < postsWrite.arrayLength - 2) {
                    query = new char[](query, ", ")
                }
            }
            MySQL conn = getDbConnection("w")
            if(!conn.execute(query)) throw new Exception("Failed to add post to database")
            postsWrite = new Post[]()
        }
    }

    Post PostsRepository:getPostById(store int postId) {
        for (int i = 0; i < postsRead.arrayLength; i++) {
            if (postsRead[i].id == postId) {
                DateTime diff = du.diff(postsRead[i].ttl, ic.getTime())
                if(du.toMilliseconds(diff) < 60000) { // 1 minute
                    return postsRead[i]    
                } else {
                    // Post expired, remove from cache
                    Post newPosts[] = new Post[]()
                    for (int j = 0; j < postsRead.arrayLength; j++) {
                        if(postsRead[j].id != postId) {
                            newPosts = new Post[](newPosts, postsRead[j])
                        }
                    }
                    postsRead = newPosts
                    break
                }
            }
        }
        
        char query[] = "SELECT * FROM posts WHERE id = $(iu.makeString(postId)) LIMIT 1"

        MySQL conn = getDbConnection("r")
        if(!conn.execute(query)) throw new Exception("Failed to fetch post from database")
        MySQLRow result[] = conn.fetchAll()
        if (result.arrayLength > 0) {
            MySQLRow row = result[0]
            int id
            int userId
            int likes
            char content[]
            DateTime ttl = ic.getTime()
            for(int i = 0; i < row.fields.arrayLength; i++) {
                if ( row.fields[i].name == "id") {
                    id = iu.intFromString(row.fields[i].value)
                } else if (row.fields[i].name == "userId") {
                    userId = iu.intFromString(row.fields[i].value)
                } else if (row.fields[i].name == "likes") {
                    likes = iu.intFromString(row.fields[i].value)
                } else if (row.fields[i].name == "content") {
                    content = row.fields[i].value
                }
            }
            Post post = new Post(id, userId, likes, content, ttl)
            postsRead = new Post[](postsRead, post) // add to cache
            return post
        }
        return null
    }

    void PostsRepository:likePost(store int postId) {
        for (int i = 0; i < postsWrite.arrayLength; i++) {
            if (postsWrite[i].id == postId) {
                postsWrite[i].likes = postsWrite[i].likes + 1
                break
            }
        }
    }

    Post[] PostsRepository:getPosts() {
        char query[] = "SELECT * FROM posts"

        MySQL conn = getDbConnection("r")
        if(!conn.execute(query)) throw new Exception("Failed to fetch post from database")
        MySQLRow result[] = conn.fetchAll()
        
        Post allPosts[] = new Post[]()

        if (result.arrayLength > 0) {
            for(int i = 0; i < result.arrayLength; i++) {
                MySQLRow row = result[i]
                int id
                int userId
                int likes
                char content[]
                for(int j = 0; j < row.fields.arrayLength; j++) {
                    if ( row.fields[j].name == "id") {
                        id = iu.intFromString(row.fields[j].value)
                    } else if (row.fields[j].name == "userId") {
                        userId = iu.intFromString(row.fields[j].value)
                    } else if (row.fields[j].name == "likes") {
                        likes = iu.intFromString(row.fields[j].value)
                    } else if (row.fields[j].name == "content") {
                        content = row.fields[j].value
                    }
                }
                Post post = new Post(id, userId, likes, content, null)
                allPosts = new Post[](allPosts, post)
            }
        }
        return allPosts
    }

    Post[] PostsRepository:getUserFeed(store int userId) {
        char query[] = "SELECT * FROM posts WHERE userId != $(iu.makeString(userId)) ORDER BY id DESC LIMIT $(iu.makeString(PAGINATION_SIZE))"

        MySQL conn = getDbConnection("r")
        if(!conn.execute(query)) throw new Exception("Failed to fetch post from database")
        MySQLRow result[] = conn.fetchAll()
        
        Post userPosts[] = new Post[]()

        if (result.arrayLength > 0) {
            for(int i = 0; i < result.arrayLength; i++) {
                MySQLRow row = result[i]
                int id
                int likes
                char content[]
                for(int j = 0; j < row.fields.arrayLength; j++) {
                    if ( row.fields[j].name == "id") {
                        id = iu.intFromString(row.fields[j].value)
                    } else if (row.fields[j].name == "likes") {
                        likes = iu.intFromString(row.fields[j].value)
                    } else if (row.fields[j].name == "content") {
                        content = row.fields[j].value
                    }
                }
                Post post = new Post(id, userId, likes, content, null)
                userPosts = new Post[](userPosts, post)
            }
        }
        return userPosts
    }
}